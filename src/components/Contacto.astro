---
const benefits = [
  { text: 'Propuesta clara y personalizada en tu correo', color: 'bg-v-blue/10 text-v-blue' },
  { text: 'Estrategia diseñada para tu servicio específico', color: 'bg-v-purple/10 text-v-purple' },
  { text: 'Garantía: si el primer mes no te convence, no pagas', color: 'bg-v-red/10 text-v-red' },
];

const serviceOptions = [
  'Estrategia y posicionamiento',
  'Marketing de contenidos',
  'Generación de oportunidades comerciales',
  'Seguimiento y análisis',
  'Fortalecimiento comercial',
  'Otro / No estoy seguro',
];

const formAction = 'https://formsubmit.co/danielcamilo@vitalmedia.com.co';
---

<section id="contacto" class="py-24 px-6 border-t border-silver-light/60">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <span class="text-sm text-v-purple font-semibold uppercase tracking-widest">Empecemos</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold mt-4 mb-6 leading-tight text-vital-blue">
        Recibe una propuesta clara enfocada en tu servicio.
      </h2>
      <p class="text-lg text-graphite mb-8 leading-relaxed">
        Llena el siguiente formulario y recibirás un correo electrónico con una propuesta clara enfocada en tu servicio.
      </p>
      <ul class="space-y-4">
        {benefits.map((benefit) => (
          <li class="flex items-center text-vital-blue">
            <span class:list={["w-8 h-8 rounded-full flex items-center justify-center mr-4 text-sm font-bold", benefit.color]}>✓</span>
            <span class="font-medium">{benefit.text}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="glass-strong p-8 md:p-10 rounded-3xl">
      <form id="contactForm" class="space-y-5" action={formAction} method="POST">
        <input type="hidden" name="_subject" value="Nueva propuesta desde Vitalmedia" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://vitalmedia.com/gracias" />

        <div>
          <label for="nombre" class="block text-sm font-medium text-vital-blue mb-2">Nombre completo</label>
          <input type="text" id="nombre" name="nombre" required class="input-field w-full px-4 py-3 rounded-xl" placeholder="Tu nombre" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-vital-blue mb-2">Email corporativo</label>
          <input type="email" id="email" name="email" required class="input-field w-full px-4 py-3 rounded-xl" placeholder="nombre@empresa.com" />
        </div>
        <div>
          <label for="organizacion" class="block text-sm font-medium text-vital-blue mb-2">Organización / IPS</label>
          <input type="text" id="organizacion" name="organizacion" required class="input-field w-full px-4 py-3 rounded-xl" placeholder="IPS, consultorio, clínica..." />
        </div>
        <div>
          <label for="servicio" class="block text-sm font-medium text-vital-blue mb-2">¿Qué servicio te interesa?</label>
          <select id="servicio" name="servicio" required class="input-field w-full px-4 py-3 rounded-xl">
            <option value="" disabled selected>Selecciona una opción</option>
            {serviceOptions.map((opt) => (
              <option>{opt}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="mensaje" class="block text-sm font-medium text-vital-blue mb-2">Cuéntanos brevemente tu servicio</label>
          <textarea id="mensaje" name="mensaje" rows="3" class="input-field w-full px-4 py-3 rounded-xl resize-none" placeholder="¿Qué tipo de servicio ofreces? ¿Qué objetivos tienes?"></textarea>
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-gradient-to-r from-v-red to-v-purple text-white py-4 rounded-xl font-semibold text-lg hover:shadow-xl hover:shadow-v-purple/30 transition-all disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer">
          Quiero mi propuesta
        </button>

        <p id="formStatus" class="text-xs text-center pt-2 leading-relaxed" aria-live="polite"></p>

        <p class="text-xs text-silver text-center pt-2 leading-relaxed">
          Tus datos están protegidos bajo la Ley 1581/2012 de Colombia. No los compartimos con terceros.
          <br />
          <span class="font-semibold text-v-red">Garantía: si el primer mes no te convence, no pagas.</span>
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    if (!form) return;
    if (form.dataset.bound === '1') return;
    form.dataset.bound = '1';

    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
    const formStatus = document.getElementById('formStatus');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !formStatus) return;

      const data = new FormData(form);

      const originalLabel = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      formStatus.textContent = '';
      formStatus.className = 'text-xs text-graphite text-center pt-2';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          submitBtn.textContent = 'Recibido — te contactamos en 24h';
          submitBtn.classList.remove('from-v-red', 'to-v-purple');
          submitBtn.classList.add('bg-green-500');
          formStatus.textContent = 'Te enviamos un correo de confirmación. Revisa tu bandeja.';
          formStatus.className = 'text-xs text-care-teal text-center pt-2 font-medium';
          form.reset();
          setTimeout(() => {
            submitBtn.textContent = originalLabel;
            submitBtn.classList.add('from-v-red', 'to-v-purple');
            submitBtn.classList.remove('bg-green-500');
            submitBtn.disabled = false;
          }, 5000);
        } else {
          throw new Error(`HTTP ${res.status}`);
        }
      } catch (err) {
        submitBtn.textContent = originalLabel;
        submitBtn.disabled = false;
        formStatus.textContent = 'No pudimos enviar el mensaje. Intenta de nuevo o escríbenos a hola@vitalmedia.com.';
        formStatus.className = 'text-xs text-pulse-coral text-center pt-2 font-medium';
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>