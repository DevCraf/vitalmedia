---
import Icon from './Icon.astro';
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex items-center justify-center w-9 h-9 rounded-full text-graphite hover:text-vital-blue hover:bg-paper-gray transition-colors cursor-pointer"
  aria-label="Cambiar tema"
>
  <Icon name="sun" size={18} class="hidden dark:block" />
  <Icon name="moon" size={18} class="block dark:hidden" />
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (_) {}
    });
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>