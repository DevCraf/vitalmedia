---
const columns = [
  {
    title: 'Servicios',
    links: [
      { label: 'SEO técnico farma', href: '#' },
      { label: 'Social media salud', href: '#' },
      { label: 'Contenido médico', href: '#' },
      { label: 'Email + CRM', href: '#' },
      { label: 'Audiovisual', href: '#' },
    ],
  },
  {
    title: 'Empresa',
    links: [
      { label: 'Nosotros', href: '#nosotros' },
      { label: 'Proceso', href: '#proceso' },
      { label: 'Contacto', href: '#contacto' },
      { label: 'Casos de estudio', href: '#' },
      { label: 'Blog', href: '#' },
    ],
  },
];
---

<footer class="pt-20 pb-10 px-6 border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
      <div class="md:col-span-1">
        <a href="#" class="block h-24 mb-6" aria-label="Vitalmedia">
          <img src="/logo.svg" alt="Vitalmedia" class="h-full w-auto" />
        </a>
        <p class="text-sm text-gray-400">
          Estrategia de Producción de Contenidos especializada en posicionamiento y ventas para el sector salud en Colombia.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">{col.title}</h4>
          <ul class="space-y-3 text-sm text-gray-400">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contacto</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li>hola@vitalmedia.com</li>
          <li>+57 (1) 234 5678</li>
          <li>Bogotá, Colombia</li>
          <li class="pt-2"><a href="#" class="hover:text-white transition-colors">LinkedIn</a> · <a href="#" class="hover:text-white transition-colors">Instagram</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-white/5 text-xs text-gray-500">
      <div class="mb-4 md:mb-0">
        © 2026 Vitalmedia. Todos los derechos reservados.
        <span class="mx-2 text-gray-700">|</span>
        Compliance Invima · Ley 1581/2012
      </div>
      <div class="flex space-x-6">
        <a href="#" class="hover:text-white transition-colors">Política de Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>

    <div class="mt-20 text-center select-none">
      <h2 class="font-display text-[15vw] md:text-[12vw] font-bold leading-none mega-footer-text">
        vitalmedia
      </h2>
    </div>
  </div>
</footer>